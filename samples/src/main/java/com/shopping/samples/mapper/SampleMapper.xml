<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.shopping.samples.dao.SampleDao">

    <!--启动缓存-->
    <!--<cache/>-->
    <!--<cache type="org.mybatis.caches.redis.RedisCache" />-->

    <!--<select id="getUserById" resultMap="userResultMap" flushCache="true">-->
    <!--select * from `user` where id = #{id}-->
    <!--</select>-->

    <select id="list" resultType="com.shopping.samples.dao.SampleDao">
        select * from sample
        <where>
            <if test="condition.id!=null">id=#{condition.id}</if>
            <if test="condition.name!=null">and name=#{condition.name}</if>
            <if test="condition.description!=null">
                and description like '%${condition.description}%'
            </if>
        </where>
    </select>

    <update id="update">
        update sample
        <set>
            <if test="sample.name!=null">name=#{sample.name},</if>
            <if test="sample.description!=null">description=#{sample.description},</if>
            <if test="sample.createTime!=null">create_time=#{sample.createTime},</if>
            <if test="sample.modifyTime!=null">modify_time=#{sample.modifyTime},</if>
        </set>
        <where>
            <if test="condition.id!=null">id=#{condition.id}</if>
            <if test="condition.name!=null">and name=#{condition.name}</if>
        </where>
    </update>


</mapper>

